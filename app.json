{
  "expo": {
    "name": "BanTayi",
    "slug": "BanTayi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bantayilogo.png",
    "scheme": "bantayi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f8faf7",
        "foregroundImage": "./assets/images/bantayilogo.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bantayilogo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bantayilogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f8faf7",
          "dark": {
            "backgroundColor": "#00342b"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "BanTayi needs access to photos so you can attach receipt or document images. Images stay on your device."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
